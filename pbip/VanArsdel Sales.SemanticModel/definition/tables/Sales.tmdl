		sourceColumn: OrderID

	column 'Product ID'
		dataType: string
		isHidden
		lineageTag: af8cb49a-13d2-4c97-8843-9a42bb6be431
		summarizeBy: none
		sourceColumn: ProductID

	column Date
		dataType: dateTime
		isHidden
		formatString: Long Date
		lineageTag: 5633df67-d89f-4553-a37c-884a8e54d01c
		summarizeBy: none
		sourceColumn: Date

		annotation UnderlyingDateTimeDataType = Date

	column 'Customer ID'
		dataType: string
		isHidden
		lineageTag: 9734bbba-280e-4247-809e-b3467d36a68b
