table Sales
	lineageTag: e51ceb0a-b1fa-40db-bfb5-90528c6016fa

	column 'Order ID'
		dataType: int64
		isHidden
		isKey
		lineageTag: 199449dd-ca03-4965-9358-f28748bebe60
