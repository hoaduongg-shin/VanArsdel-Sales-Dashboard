	partition Sales = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(DataFolder & "Sales.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    Typed = Table.TransformColumnTypes(Promoted, {{"OrderID", Int64.Type}, {"ProductID", type text}, {"Date", type date}, {"CustomerID", type text}, {"CampaignID", Int64.Type}, {"Units", Int64.Type}})
				in
				    Typed

