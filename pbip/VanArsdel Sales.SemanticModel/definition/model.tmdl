model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DataFolder","Date","Product","Customer","Geo","Campaign","Sales","BudgetForecast"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table Date
ref table Product
ref table Customer
ref table Geo
ref table Campaign
ref table Sales
ref table BudgetForecast
ref table 'P&L Stage'
ref table 'Key Measures'

